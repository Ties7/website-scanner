---
import { scanWebsite } from '../lib/scanner.js';

let resultaat = null;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const url = formData.get('url');
  resultaat = await scanWebsite(url);
}
---
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
  </head>
  <body>
    <form method="POST">
      <input type="text" name="url" placeholder="bijv. cafegeorge.nl" required />
      <button type="submit">Scan</button>
    </form>

	{resultaat && (
		<p>{resultaat.url} - {resultaat.verdict} (SEO: {resultaat.seoScore}, Performance: {resultaat.performanceScore})</p>
	)}
  </body>
</html>